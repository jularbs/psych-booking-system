{
  "name": "@booking-platform/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:all": "pnpm nx run-many -t lint --all",
    "test:all": "pnpm nx run-many -t test --all",
    "build:all": "pnpm nx run-many -t build --all",
    "dev:api": "pnpm nx serve api",
    "dev:web": "pnpm nx serve web",
    "test:api": "pnpm nx test api",
    "prepare": "husky",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "db:ps": "docker compose ps",
    "db:migration:new": "dotenv -e .env -- dbmate new",
    "db:migrate": "dotenv -e .env -- dbmate --url \"$DATABASE_URL\" up",
    "db:rollback": "dotenv -e .env -- dbmate --url \"$DATABASE_URL\" rollback",
    "db:status": "dotenv -e .env -- dbmate --url \"$DATABASE_URL\" status"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md,scss,yml,yaml}": [
      "prettier --write"
    ]
  },
  "private": true,
  "devDependencies": {
